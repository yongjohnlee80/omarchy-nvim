#!/usr/bin/env bash
set -euo pipefail

script_dir="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(CDPATH= cd -- "${script_dir}/.." && pwd)"
bootstrap="${repo_root}/codex/scripts/link-nvim-codex.sh"

trusted=0
force_new=0
no_alt_screen=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --trusted)
      trusted=1
      shift
      ;;
    --new)
      force_new=1
      shift
      ;;
    --no-alt-screen)
      no_alt_screen=1
      shift
      ;;
    -h|--help)
      cat <<'EOF'
Usage:
  codex-nvim [--trusted] [--new] [--no-alt-screen]

Starts Codex from the Neovim integration, bootstraps the repo-local Codex bundle,
and shows a short Neovim-specific welcome note before launching.
EOF
      exit 0
      ;;
    *)
      printf 'codex-nvim: unknown argument: %s\n' "$1" >&2
      exit 1
      ;;
  esac
done

if ! command -v codex >/dev/null 2>&1; then
  printf 'codex-nvim: codex is not available on PATH\n' >&2
  exit 1
fi

"${bootstrap}" >/dev/null 2>&1 || true

startup_prompt="$(cat <<'EOF'
You were launched from a Neovim Codex integration.

Repo-local Neovim Codex skills are bundled and should be preferred for:
- `shell`
- `toggle-diff-editor`

Important Neovim RPC rule:
- shell injection and diff-editor review use Neovim RPC over a Unix socket
- in Codex-hosted environments, prefer the outside-sandbox execution path for those actions

Behavior default for this Neovim session:
- treat diff-editor mode as on by default for non-trivial edits unless the user turns it off
- if the user asks for `/toggle-diff-editor on` or `/toggle-diff-editor off`, follow that preference
- if the user asks for immediate direct edits, follow that request
EOF
)"

printf 'Neovim Codex launcher\n'
printf 'Tip: use /toggle-diff-editor on|off to control the live patch preview workflow.\n'
if [ "${trusted}" -eq 1 ]; then
  printf 'Mode: trusted. Neovim RPC actions can run without sandbox approval prompts.\n'
else
  printf 'Mode: safe. For frictionless Neovim RPC, enable trusted mode in the config.\n'
fi
printf '\n'

codex_args=()
if [ "${trusted}" -eq 1 ]; then
  codex_args+=("-a" "never" "-s" "danger-full-access")
fi

if [ "${force_new}" -eq 1 ]; then
  if [ "${no_alt_screen}" -eq 1 ]; then
    codex_args+=("--no-alt-screen")
  fi
  exec codex "${codex_args[@]}" "${startup_prompt}"
fi

resume_args=("resume" "--last")
if [ "${no_alt_screen}" -eq 1 ]; then
  resume_args+=("--no-alt-screen")
fi

if codex "${codex_args[@]}" "${resume_args[@]}"; then
  exit 0
fi

if [ "${no_alt_screen}" -eq 1 ]; then
  codex_args+=("--no-alt-screen")
fi
exec codex "${codex_args[@]}" "${startup_prompt}"
