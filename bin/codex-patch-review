#!/usr/bin/env bash
set -euo pipefail

die() {
  printf 'codex-patch-review: %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

usage() {
  cat <<'EOF'
Usage:
  codex-patch-review <patch-file> <project-root> [title]

Interactive controls:
  ctrl-a   accept and apply the patch
  ctrl-d   deny and discard the patch
  ctrl-e   edit the patch file in $EDITOR
  enter    inspect the selected file in less
  esc      discard the patch
EOF
}

preview_error=""
preview_root=""
patch_file=""
project_root=""
title=""

cleanup() {
  if [ -n "${preview_root}" ] && [ -d "${preview_root}" ]; then
    rm -rf "${preview_root}"
  fi
}
trap cleanup EXIT

read_targets() {
  awk '
    /^diff --git a\// {
      old=$3
      new=$4
      sub("^a/", "", old)
      sub("^b/", "", new)
      print old "\t" new
    }
  ' "${patch_file}"
}

display_path_for() {
  local old_path="$1"
  local new_path="$2"
  if [ "${new_path}" != "/dev/null" ]; then
    printf '%s\n' "${new_path}"
  else
    printf '%s\n' "${old_path}"
  fi
}

map_target() {
  local display="$1"
  read_targets | while IFS=$'\t' read -r old_path new_path; do
    local candidate
    candidate="$(display_path_for "${old_path}" "${new_path}")"
    if [ "${candidate}" = "${display}" ]; then
      printf '%s\t%s\n' "${old_path}" "${new_path}"
      return 0
    fi
  done
}

list_files() {
  local line old_path new_path
  while IFS=$'\t' read -r old_path new_path; do
    display_path_for "${old_path}" "${new_path}"
  done < <(read_targets)
}

copy_originals() {
  local old_path new_path src dst
  while IFS=$'\t' read -r old_path new_path; do
    if [ "${old_path}" = "/dev/null" ]; then
      continue
    fi
    src="${project_root}/${old_path}"
    dst="${preview_root}/${old_path}"
    if [ -f "${src}" ]; then
      mkdir -p "$(dirname "${dst}")"
      cp "${src}" "${dst}"
    fi
  done < <(read_targets)
}

apply_to_preview() {
  # Capture error output into files outside preview_root so they survive
  # the reset we do between the strict and fuzzy apply attempts.
  local err_git err_patch git_err patch_err rej_files patch_rc
  err_git="$(mktemp)"
  err_patch="$(mktemp)"

  # Attempt 1 — strict git apply. --recount fixes hunk counts after an edit;
  # --whitespace=nowarn tolerates trailing-whitespace drift.
  if (cd "${preview_root}" && git apply --recount --whitespace=nowarn "${patch_file}") \
      >/dev/null 2>"${err_git}"; then
    rm -f "${err_git}" "${err_patch}"
    return 0
  fi
  git_err="$(cat "${err_git}" 2>/dev/null || true)"

  if ! command -v patch >/dev/null 2>&1; then
    printf '%s\n' "${git_err}" > "${preview_root}/apply.err"
    rm -f "${err_git}" "${err_patch}"
    return 1
  fi

  # Attempt 2 — GNU patch with fuzz. Start from a clean copy of originals
  # because git apply may have written partial changes before bailing.
  # Keep the preview_root directory itself so no paths dangle.
  find "${preview_root}" -mindepth 1 -delete 2>/dev/null || true
  copy_originals
  patch_rc=0
  (cd "${preview_root}" && patch -p1 --forward --fuzz=2 --no-backup-if-mismatch \
        -s -i "${patch_file}") >>"${err_patch}" 2>>"${err_patch}" || patch_rc=$?
  patch_err="$(cat "${err_patch}" 2>/dev/null || true)"
  rej_files="$(find "${preview_root}" -name '*.rej' -print 2>/dev/null || true)"

  # Full success is exit 0 AND no .rej files — otherwise the fuzz pass
  # silently dropped hunks (the "25 changes but only one showed up" case).
  if [ "${patch_rc}" -eq 0 ] && [ -z "${rej_files}" ]; then
    rm -f "${err_git}" "${err_patch}"
    return 0
  fi

  {
    printf 'git apply failed:\n'
    printf '%s\n' "${git_err}" | sed 's/^/  /'
    if [ -n "${patch_err}" ]; then
      printf '\npatch --fuzz=2 output:\n'
      printf '%s\n' "${patch_err}" | sed 's/^/  /'
    fi
    if [ -n "${rej_files}" ]; then
      printf '\nHunks that could not be matched (these would be skipped):\n'
      while IFS= read -r rej; do
        printf '  %s\n' "${rej#${preview_root}/}"
      done <<< "${rej_files}"
      printf '\nFix the patch with ctrl-e so these hunks land, or reject the patch.\n'
    fi
  } > "${preview_root}/apply.err"
  rm -f "${err_git}" "${err_patch}"
  return 1
}

rebuild_preview() {
  cleanup
  preview_root="$(mktemp -d)"
  preview_error=""
  copy_originals
  if ! apply_to_preview; then
    preview_error="$(cat "${preview_root}/apply.err" 2>/dev/null || true)"
  fi
}

preview_file() {
  local display="$1"
  local mapped old_path new_path old_abs new_abs

  if [ -n "${preview_error}" ]; then
    printf 'Patch preview is invalid:\n\n%s\n' "${preview_error}"
    return 0
  fi

  mapped="$(map_target "${display}" || true)"
  [ -n "${mapped}" ] || {
    printf 'No target data for %s\n' "${display}"
    return 0
  }

  old_path="${mapped%%$'\t'*}"
  new_path="${mapped#*$'\t'}"
  old_abs=""
  new_abs=""

  if [ "${old_path}" != "/dev/null" ]; then
    old_abs="${project_root}/${old_path}"
  fi
  if [ "${new_path}" != "/dev/null" ]; then
    new_abs="${preview_root}/${new_path}"
  fi

  printf 'File: %s\n\n' "${display}"

  if [ -z "${old_abs}" ] || [ ! -f "${old_abs}" ]; then
    printf 'New file\n\n'
    if [ -n "${new_abs}" ] && [ -f "${new_abs}" ]; then
      bat --style=plain --color=always "${new_abs}" || cat "${new_abs}"
    fi
    return 0
  fi

  if [ -z "${new_abs}" ] || [ ! -e "${new_abs}" ]; then
    printf 'Deleted file\n\n'
    bat --style=plain --color=always "${old_abs}" || cat "${old_abs}"
    return 0
  fi

  git --no-pager diff --no-index --color=always -- "${old_abs}" "${new_abs}" || true
}

inspect_file() {
  local display="$1"
  preview_file "${display}" | less -R
}

refresh_nvim() {
  if [ -n "${NVIM:-}" ] && command -v nvim >/dev/null 2>&1; then
    nvim --server "${NVIM}" --remote-send "<cmd>checktime<cr>" >/dev/null 2>&1 || true
  fi
}

apply_patch() {
  if (cd "${project_root}" && git apply --check --recount --whitespace=nowarn "${patch_file}") 2>/dev/null; then
    (cd "${project_root}" && git apply --recount --whitespace=nowarn "${patch_file}") || return 1
    refresh_nvim
    rm -f "${patch_file}"
    printf 'Patch applied.\n'
    return 0
  fi

  if ! command -v patch >/dev/null 2>&1; then
    printf 'git apply rejected the patch and GNU patch is not available.\n' >&2
    return 1
  fi

  # Dry-run first so we only touch the working tree if every hunk lands
  # cleanly (with fuzz). This avoids a half-applied patch that would require
  # the user to manually revert the pieces that did go in.
  local dry_err
  dry_err="$(mktemp)"
  if ! (cd "${project_root}" && patch -p1 --forward --fuzz=2 --dry-run -s -i "${patch_file}") \
        >>"${dry_err}" 2>>"${dry_err}"; then
    printf 'Patch would only apply partially (GNU patch --fuzz=2 rejected some hunks):\n\n' >&2
    sed 's/^/  /' "${dry_err}" >&2
    printf 'Nothing was changed. Edit the patch (ctrl-e) or discard it (ctrl-d).\n' >&2
    rm -f "${dry_err}"
    return 1
  fi
  rm -f "${dry_err}"

  (cd "${project_root}" && patch -p1 --forward --fuzz=2 --no-backup-if-mismatch \
        -s -i "${patch_file}") || return 1
  refresh_nvim
  rm -f "${patch_file}"
  printf 'Patch applied (with fuzz).\n'
  return 0
}

deny_patch() {
  rm -f "${patch_file}"
  printf 'Patch discarded.\n'
  return 0
}

main() {
  local key="" selected="" result="" editor=""
  need_cmd git
  need_cmd fzf
  need_cmd less
  need_cmd bat

  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    usage
    exit 0
  fi

  [ "$#" -ge 2 ] || {
    usage >&2
    exit 1
  }

  patch_file="$1"
  project_root="$2"
  title="${3:-Codex Patch Review}"

  [ -f "${patch_file}" ] || die "patch file does not exist: ${patch_file}"
  [ -d "${project_root}" ] || die "project root does not exist: ${project_root}"

  if [ "${CODEX_PATCH_REVIEW_ACTION:-}" = "accept" ]; then
    rebuild_preview
    apply_patch
    exit $?
  fi
  if [ "${CODEX_PATCH_REVIEW_ACTION:-}" = "deny" ]; then
    deny_patch
    exit 0
  fi

  while true; do
    rebuild_preview
    result="$(
      list_files | fzf \
        --ansi \
        --layout=reverse \
        --height=100% \
        --border \
        --prompt="review> " \
        --header="${title} | ctrl-a accept | ctrl-d deny | ctrl-e edit patch | enter inspect" \
        --preview-window='right:70%:wrap' \
        --preview="$0 --preview-file '${patch_file}' '${project_root}' '{}'" \
        --expect=ctrl-a,ctrl-d,ctrl-e,enter
    )" || {
      deny_patch
      exit 1
    }

    key="$(printf '%s\n' "${result}" | sed -n '1p')"
    selected="$(printf '%s\n' "${result}" | sed -n '2p')"

    case "${key}" in
      ctrl-a)
        if apply_patch; then
          exit 0
        fi
        printf '\nPatch apply failed. Press enter to continue.\n' >&2
        IFS= read -r _ || true
        ;;
      ctrl-d)
        deny_patch
        exit 1
        ;;
      ctrl-e)
        editor="${EDITOR:-vi}"
        "${editor}" "${patch_file}"
        ;;
      enter|"")
        [ -n "${selected}" ] && inspect_file "${selected}"
        ;;
    esac
  done
}

if [ "${1:-}" = "--preview-file" ]; then
  patch_file="$2"
  project_root="$3"
  preview_root=""
  title=""
  rebuild_preview
  preview_file "${4:-}"
  exit 0
fi

main "$@"
